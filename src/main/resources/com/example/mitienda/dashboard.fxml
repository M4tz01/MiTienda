<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.mitienda.DashboardController"
            prefWidth="1100" prefHeight="650">

    <left>
        <VBox spacing="20" style="-fx-background-color: #111827;" prefWidth="230">
            <padding>
                <Insets top="20" right="15" bottom="20" left="15"/>
            </padding>

            <VBox spacing="2">
                <Label text="MiTienda" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label text="Sistema de Ventas" style="-fx-font-size: 11; -fx-text-fill: #9ca3af;"/>
            </VBox>

            <VBox style="-fx-background-color: #1f2937; -fx-background-radius: 6; -fx-padding: 8;">
                <Label text="admin" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label text="• En línea" style="-fx-font-size: 11; -fx-text-fill: #10b981;"/>
            </VBox>

            <Separator style="-fx-opacity: 0.1;"/>

            <VBox spacing="6" VBox.vgrow="ALWAYS">
                <Label text="MENU PRINCIPAL" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #6b7280; -fx-padding: 0 0 5 0;"/>
                <Button text="🏠 Inicio" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #d1d5db; -fx-cursor: hand;"/>
                <Button text="📦 Productos" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;"/>
                <Button text="📁 Categorías" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #d1d5db; -fx-cursor: hand;"/>
                <Button text="👥 Clientes" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #d1d5db; -fx-cursor: hand;"/>
                <Button text="🛒 Ventas" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #d1d5db; -fx-cursor: hand;"/>
                <Button text="📊 Reportes" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #d1d5db; -fx-cursor: hand;"/>
                <Button text="⚙️ Usuarios" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #d1d5db; -fx-cursor: hand;"/>
            </VBox>

            <Button text="🛑 Cerrar sesión" maxWidth="Infinity" alignment="BASELINE_LEFT" style="-fx-background-color: transparent; -fx-text-fill: #ef4444; -fx-cursor: hand;"/>
        </VBox>
    </left>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: #f8fafc; -fx-background-insets: 0;">
            <VBox spacing="20" style="-fx-background-color: #f8fafc;">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <Label text="Productos" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>

                <VBox spacing="15" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                    <Label text="│ Registro / Edición de Producto" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #334155;"/>

                    <GridPane hgap="15" vgap="15">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="33.3"/>
                            <ColumnConstraints percentWidth="33.3"/>
                            <ColumnConstraints percentWidth="33.3"/>
                        </columnConstraints>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <Label text="Código del producto" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <TextField fx:id="txtCodigo" promptText="Ej: P001" style="-fx-padding: 6; -fx-border-color: #e2e8f0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <Label text="Nombre del producto" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <TextField fx:id="txtNombre" promptText="Ingrese el nombre" style="-fx-padding: 6; -fx-border-color: #e2e8f0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <Label text="Categoría" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <ComboBox fx:id="cbCategoria" promptText="Seleccione una categoría" maxWidth="Infinity" style="-fx-padding: 3; -fx-border-color: #e2e8f0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                        </VBox>

                        <VBox spacing="4" GridPane.columnIndex="0" GridPane.rowIndex="1">
                            <Label text="Precio" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <TextField fx:id="txtPrecio" promptText="$ 0.00" style="-fx-padding: 6; -fx-border-color: #e2e8f0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <Label text="Stock" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <TextField fx:id="txtStock" promptText="0" style="-fx-padding: 6; -fx-border-color: #e2e8f0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                        </VBox>
                        <VBox spacing="4" GridPane.columnIndex="2" GridPane.rowIndex="1">
                            <Label text="Estado" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                            <ComboBox fx:id="cbEstado" promptText="Activo" maxWidth="Infinity" style="-fx-padding: 3; -fx-border-color: #e2e8f0; -fx-border-radius: 4; -fx-background-radius: 4;"/>
                        </VBox>
                    </GridPane>

                    <HBox spacing="10">
                        <padding>
                            <Insets top="10"/>
                        </padding>
                        <Button text="+ Nuevo" onAction="#handleLimpiar" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 7 14; -fx-background-radius: 5; -fx-cursor: hand;"/>
                        <Button text="💾 Guardar" onAction="#handleGuardar" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 7 14; -fx-background-radius: 5; -fx-cursor: hand;"/>
                        <Button text="✏️ Actualizar" onAction="#handleActualizar" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 7 14; -fx-background-radius: 5; -fx-cursor: hand;"/>
                        <Button text="🗑️ Eliminar" onAction="#handleEliminar" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 7 14; -fx-background-radius: 5; -fx-cursor: hand;"/>
                        <Button text="🔄 Limpiar" onAction="#handleLimpiar" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 7 14; -fx-background-radius: 5; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <VBox spacing="10" style="-fx-background-color: #ffffff; -fx-background-radius: 8; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 2);">
                    <Label text="📋 Lista de Productos" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #334155;"/>

                    <TableView fx:id="tblProductos" prefHeight="260">
                        <columns>
                            <TableColumn fx:id="colCodigo" text="Código" prefWidth="90"/>
                            <TableColumn fx:id="colNombre" text="Nombre" prefWidth="250"/>
                            <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="130"/>
                            <TableColumn fx:id="colPrecio" text="Precio" prefWidth="100"/>
                            <TableColumn fx:id="colStock" text="Stock" prefWidth="90"/>
                            <TableColumn fx:id="colEstado" text="Estado" prefWidth="110"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>