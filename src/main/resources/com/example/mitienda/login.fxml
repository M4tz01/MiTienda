<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.example.mitienda.LoginController"
           prefWidth="500" prefHeight="500" style="-fx-background-color: #f4f6f9;">

    <VBox spacing="20" alignment="CENTER" maxWidth="380" maxHeight="450"
          style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
        <padding>
            <Insets top="30" right="35" bottom="30" left="35"/>
        </padding>

        <VBox spacing="2" alignment="CENTER_LEFT" maxWidth="Infinity">
            <Label text="MiTienda" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
            <Label text="Sistema de Ventas" style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>
        </VBox>

        <Label text="Iniciar sesión" maxWidth="Infinity" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #334155;"/>

        <VBox spacing="12" maxWidth="Infinity">
            <VBox spacing="4">
                <Label text="Usuario" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <TextField fx:id="txtUsuario" promptText="Ej: admin"
                           style="-fx-background-radius: 5; -fx-padding: 7; -fx-border-color: #cbd5e1; -fx-border-radius: 5;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Contraseña" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <PasswordField fx:id="txtContrasena" promptText="••••••••"
                               style="-fx-background-radius: 5; -fx-padding: 7; -fx-border-color: #cbd5e1; -fx-border-radius: 5;"/>
            </VBox>

            <VBox spacing="4">
                <Label text="Rol" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                <ComboBox fx:id="cbRol" promptText="- Seleccionar -" maxWidth="Infinity"
                          style="-fx-background-radius: 5; -fx-padding: 4; -fx-border-color: #cbd5e1; -fx-border-radius: 5;"/>
            </VBox>
        </VBox>

        <Button fx:id="btnIngresar" text="🚪 Ingresar" onAction="#handleLogin" maxWidth="Infinity"
                style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14; -fx-background-radius: 5; -fx-padding: 8; -fx-cursor: hand;"/>

        <Label text="admin / 1234 / Administrador" style="-fx-font-size: 11; -fx-text-fill: #94a3b8;"/>
    </VBox>
</StackPane>